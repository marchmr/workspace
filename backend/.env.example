# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mike_workspace
DB_USER=mike_app
DB_PASSWORD=

# Encryption
ENCRYPTION_KEY=

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# auto = nur bei HTTPS secure setzen, true/false = erzwingen
COOKIE_SECURE=auto

# Server
PORT=3000
NODE_ENV=production

# Update (GitHub Releases)
UPDATE_URL=https://api.github.com/repos/marchmr/workspace
UPDATE_REQUIRE_HASH=true


# Dokumente
DOCUMENT_STORAGE_PROVIDER=local
DOCUMENT_MAX_FILE_SIZE_MB=25
DOCUMENT_ALLOW_ALL_MIME_TYPES=false

# File Security / Dateiaustausch
FILE_SECURITY_MAX_UPLOAD_MB=500
FILE_SECURITY_STRICT_SIGNATURE=true
FILE_SECURITY_ALLOW_ZIP_UPLOADS=false
FILE_SECURITY_ZIP_MAX_ENTRIES=500
FILE_SECURITY_ZIP_MAX_UNCOMPRESSED_MB=1000
FILE_SECURITY_ZIP_MAX_RATIO=60
FILE_SECURITY_CLAMAV_ENABLED=false
FILE_SECURITY_CLAMAV_BINARY=clamscan
FILE_SECURITY_CLAMAV_TIMEOUT_MS=120000
FILE_SECURITY_CLAMAV_FAIL_CLOSED=false

# App (optional override; normalerweise automatisch aus backend/package.json)
# APP_VERSION=1.0.0
